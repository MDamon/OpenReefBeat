# ReefBeat account credentials (same login as your phone app)
REEFBEAT_USERNAME=your_email@example.com
REEFBEAT_PASSWORD=your_password
REEFBEAT_CLIENT_CREDENTIALS=see-docs/REVERSE_ENGINEERING.md-to-capture-this

# Display settings
TIMEZONE=America/New_York
LOCATION=Office

# History retention (days, default 30)
# HISTORY_DAYS=30

# Device IDs — OPTIONAL. Auto-discovered from your account if not set.
# Only needed if you have multiple aquariums and want to pick a specific one.
# AQUARIUM_UID=your-aquarium-uid
# ATO_HWID=your-ato-hwid
# PUMP_HWID=your-pump-hwid
# LIGHT_HWIDS=light-hwid-1,light-hwid-2
# REEFMAT_HWID=your-reefmat-hwid
